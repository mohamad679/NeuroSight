APP_ENV=local
NEUROSIGHT_API_KEY=change-me-in-production

# Phase 1 runtime contract
NEUROSIGHT_RUNTIME_MODE=demo
NEUROSIGHT_CLASS_MODE=six_class_demo

# Local UI -> Hugging Face/FastAPI backend
BACKEND_URL=https://mohi679-neurosight.hf.space
HOST=127.0.0.1
PORT=7861
NEUROSIGHT_FRONTEND_TIMEOUT_SECONDS=300

# Upload and data safety limits
NEUROSIGHT_MAX_UPLOAD_BYTES=104857600
NEUROSIGHT_MAX_DICOM_ZIP_MEMBERS=2000
NEUROSIGHT_MAX_DICOM_ZIP_UNCOMPRESSED_BYTES=536870912
NEUROSIGHT_MAX_MRI_VALUES=67108864
NEUROSIGHT_MAX_EEG_VALUES=67108864

# Optional authorized ADNI-style data locations. Do not commit private data.
NEUROSIGHT_DEMO_CSV_PATH=data/ADNIMERGE_synthetic.csv
NEUROSIGHT_PATIENT_CSV_PATH=
NEUROSIGHT_MRI_DIR=data/mri
NEUROSIGHT_EEG_DIR=data/eeg
NEUROSIGHT_DATA_CSV_PATH=data/ADNIMERGE_synthetic.csv

# Optional local services
POSTGRES_PASSWORD=change-me
NEO4J_PASSWORD=change-me
